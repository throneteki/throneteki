{
    env: 'development',
    // This is for specific instance-based data which will be passed into each game; not required.
    //instance: {
    //    type: 'development'
    //},

    secret: 'somethingverysecret',
    hmacSecret: 'somethingevenmoresecret',

    //captchaKey: 'captchaKey',
    awsSesRegion: 'eu-west-1',
    //awsAccessKeyId: 'AKIA...',
    //awsSecretAccessKey: '...',
    emailFrom: 'The Iron Throne <noreply@theironthrone.net>',
    //emailReplyTo: 'support@example.com',

    dbPath: 'mongodb://mongo:27017/throneteki',
    // This is the host/port of the Zero MQ server which does the node load balancing
    requireActivation: false,
    appName: 'The Iron Throne',

    redisUrl: 'redis://redis/',
    redisKeyPrefix: 'local',
    //ipQualityScoreKey: 'api-key',
    //proxyCheckKey: 'api-key',
    ipQualityScoreCacheTtlSeconds: 2592000,
    ipQualityScoreUnknownCacheTtlSeconds: 900,
    proxyCheckCacheTtlSeconds: 2592000,
    proxyCheckUnknownCacheTtlSeconds: 900,
    disposableEmailCacheTtlSeconds: 15552000,
    disposableEmailUnknownCacheTtlSeconds: 900,
    maintenanceCleanupIntervalMs: 21600000,
    refreshTokenRetentionDays: 30,
    sessionHistoryRetentionDays: 180,
    origin: 'http://localhost:4000',
    minLobbyChatTime: 0, // The time (in seconds) an account has to be registered before it can chat in the lobby
    nodeIdentity: 'node1',
    socketioPort: 5000
}
